{
  "manifest_version": 3,
  "name": "CyberClowns Phishing Detector",
  "version": "1.0",
  "description": "Detect phishing attacks and suspicious websites in real-time",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "webRequest",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://20.244.15.36:8080/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["splunk_logger.js", "content.js", "overlay.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "CyberClowns Phishing Detector"
  },
  "web_accessible_resources": [
    {
      "resources": ["demo/demo_mode.js", "demo/demo_dashboard.html", "test_page/phishing_demo.html", "onboarding.html", "blocked.html"],
      "matches": ["<all_urls>"]
    }
  ]
}

