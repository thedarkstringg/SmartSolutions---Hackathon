{
  "manifest_version": 3,
  "name": "Tilloff - Advanced Phishing Analyzer",
  "version": "1.0",
  "description": "Advanced phishing detection and security analysis powered by machine learning",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "webRequest",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://20.244.15.36:8080/*",
    "https://tszkdmqjuoxfxbnsdfmw.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["splunk_logger.js", "content.js", "overlay.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Tilloff - Advanced Phishing Analyzer"
  },
  "web_accessible_resources": [
    {
      "resources": ["icon.png", "demo/demo_mode.js", "demo/demo_dashboard.html", "test_page/phishing_demo.html", "onboarding.html", "blocked.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' https://cdn.jsdelivr.net; connect-src 'self' https://tszkdmqjuoxfxbnsdfmw.supabase.co https://cdn.jsdelivr.net"
  }
}



