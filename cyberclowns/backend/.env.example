# CyberClowns Splunk Integration Configuration
# Copy this to backend/.env and fill in your values

# ===== Google Gemini API (Optional but recommended) =====
GEMINI_API_KEY=your_gemini_api_key_here

# ===== Splunk HEC Configuration =====
# Splunk Host (IP or hostname)
SPLUNK_HOST=34.200.46.182

# Splunk HEC Port (default 8088)
SPLUNK_PORT=8088

# Splunk HEC Token
SPLUNK_TOKEN=08467373-6f2b-4d5c-a099-222c25412616

# Verify SSL certificates (set to false for self-signed certs)
VERIFY_SSL=false

# ===== Optional Settings =====
# Enable verbose logging
DEBUG=false
